# ============================================================
# Portfolio Admin Dashboard — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values before running.
# Never commit .env to version control.

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------

# Port the Express API server listens on (default: 3000)
PORT=3000

# Node environment: development | production | test
NODE_ENV=development

# ------------------------------------------------------------
# Authentication
# ------------------------------------------------------------

# Admin username used to log in to the dashboard (default: admin)
ADMIN_USERNAME=admin

# Admin password — required on first startup to seed credentials.
# Must be at least 12 characters. Use a strong, unique password.
ADMIN_PASSWORD=your-secure-password-here

# Secret used to sign session tokens / CSRF tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-32-byte-hex-string

# Session duration in milliseconds (default: 86400000 = 24 hours)
SESSION_DURATION_MS=86400000

# ------------------------------------------------------------
# CORS / Client
# ------------------------------------------------------------

# URL of the Vue frontend (used for CORS allow-origin).
# In production set this to your actual domain, e.g. https://example.com
CLIENT_URL=http://localhost:5173

# ------------------------------------------------------------
# Supabase (optional — used in production for persistent storage)
# If not set, data is stored in data/portfolio-data.json (local dev)
# ------------------------------------------------------------

# Your Supabase project URL — found in Project Settings > API
# SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Service Role key (secret) — found in Project Settings > API > service_role
# WARNING: Never expose this key to the frontend or commit it to git
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------------------------------------------------------------
# Data & Backups (file-based, used when Supabase is NOT configured)
# ------------------------------------------------------------

# Maximum number of backup files to keep (default: 10)
# BACKUP_MAX_COUNT=10
