{
  "name": "portofolio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix --cache",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "start": "node --loader ts-node/esm server/index.ts",
    "start:prod": "NODE_ENV=production npx tsx server/index.ts",
    "build:full": "npm run build-only && echo 'Frontend built successfully'"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "@types/multer": "^2.1.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "8.5.2",
    "multer": "^2.1.1",
    "pinia": "^3.0.3",
    "uuid": "^14.0.0",
    "vue": "^3.5.22",
    "vue-router": "^4.6.3",
    "xss": "1.0.15",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.18.11",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/ui": "^4.1.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.37.0",
    "eslint-plugin-vue": "~10.5.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.6.2",
    "supertest": "^7.2.2",
    "tsx": "^4.22.3",
    "typescript": "~5.9.0",
    "vite": "^7.1.11",
    "vite-plugin-vue-devtools": "^8.0.3",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.1.1"
  }
}
